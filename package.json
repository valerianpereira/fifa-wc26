{
  "name": "fifa-wc26",
  "version": "0.1.1",
  "description": "FIFA World Cup 2026 CLI: fixtures, live scores, group standings, ASCII bracket, team lookup. Keyless providers, smart cache, terminal-friendly output.",
  "type": "module",
  "bin": {
    "wc26": "dist/cli.js",
    "fifa-wc26": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'tests/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "fifa",
    "world-cup",
    "wc26",
    "world-cup-2026",
    "football",
    "soccer",
    "cli",
    "fixtures",
    "live-scores",
    "bracket",
    "standings",
    "terminal",
    "tui"
  ],
  "author": "Valerian Pereira",
  "license": "MIT",
  "homepage": "https://github.com/valerianpereira/fifa-wc26#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valerianpereira/fifa-wc26.git"
  },
  "bugs": {
    "url": "https://github.com/valerianpereira/fifa-wc26/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-table": "^3.1.0",
    "react": "^18.3.1",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "ink-testing-library": "^4.0.0",
    "msw": "^2.3.5",
    "prettier": "^3.3.3",
    "tsup": "^8.2.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
